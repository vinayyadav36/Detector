FLASK_ENV=development
SECRET_KEY=change-me-in-production
DATABASE_URL=sqlite:///detector.db
ANALYZE_RATE_LIMIT=30/hour
REQUEST_TIMEOUT_SECONDS=10
MAX_REDIRECT_DEPTH=5

# Scoring thresholds (score < SUSPICIOUS_THRESHOLD = safe, >= SUSPICIOUS_THRESHOLD = suspicious, >= PHISHING_THRESHOLD = phishing)
SUSPICIOUS_THRESHOLD=25
PHISHING_THRESHOLD=50

# Domain age penalties
NEW_DOMAIN_DAYS=7
YOUNG_DOMAIN_DAYS=30
NEW_DOMAIN_PENALTY=20
YOUNG_DOMAIN_PENALTY=10

# API keys
WHOIS_API_KEY=

# VirusTotal (optional enrichment, disabled by default)
VT_ENABLED=false
VT_API_KEY=
VT_TIMEOUT=10
VT_SCORE_BUMP_MALICIOUS=15
VT_SCORE_BUMP_SUSPICIOUS=5
VT_MAX_BUMP_MALICIOUS=30
VT_MAX_BUMP_SUSPICIOUS=10

RESULTS_DIR=results

